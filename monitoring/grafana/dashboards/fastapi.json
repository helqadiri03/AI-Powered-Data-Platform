{
  "title": "AI E-Commerce API Dashboard",
  "uid": "ecommerce-api-001",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total HTTP Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Requests per Minute",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "round(sum(rate(http_requests_total[1m])) * 60, 0.01)",
          "legendFormat": "Req/min",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (4xx + 5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      }
    },
    {
      "id": 4,
      "title": "p99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[2m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 7,
      "title": "HTTP Status Codes Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[2m])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 8,
      "title": "Process Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "A"
        },
        {
          "expr": "process_virtual_memory_bytes",
          "legendFormat": "Virtual Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 9,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m]) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 10,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "Open FDs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },

    { "id": 11, "type": "text", "title": "— AI Pipeline Metrics —",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 28 },
      "options": { "content": "## ⚡ AI Pipeline — Pinecone · LLM · SQL · Airflow", "mode": "markdown" }
    },

    {
      "id": 12,
      "title": "Pinecone Retrieval Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(pinecone_retrieval_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(pinecone_retrieval_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(pinecone_retrieval_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 13,
      "title": "LLM Generation Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llm_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(llm_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(llm_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 14,
      "title": "SQL Generation Time (LLM → SQL)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sql_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(sql_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(sql_generation_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 15,
      "title": "Snowflake SQL Execution Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sql_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(sql_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(sql_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 16,
      "title": "RAG Requests (Success vs Error)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(rag_requests_total{status=\"success\"}[2m]))", "legendFormat": "Success", "refId": "A" },
        { "expr": "sum(rate(rag_requests_total{status=\"error\"}[2m]))", "legendFormat": "Error", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 17,
      "title": "SQL Requests (Success vs Error)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(sql_requests_total{status=\"success\"}[2m]))", "legendFormat": "Success", "refId": "A" },
        { "expr": "sum(rate(sql_requests_total{status=\"error\"}[2m]))", "legendFormat": "Error", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 18,
      "title": "Airflow DAG Duration (via StatsD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 54 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "airflow_dagrun_duration_success", "legendFormat": "DAG: {{dag_id}} (success)", "refId": "A" },
        { "expr": "airflow_dagrun_duration_failed", "legendFormat": "DAG: {{dag_id}} (failed)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } }
    }
  ]
}